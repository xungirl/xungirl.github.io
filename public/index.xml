&lt;div&gt;
  &lt;img src=&#34;https://tuchuang-1312256370.cos.ap-shanghai.myqcloud.com/flutter.svg&#34; alt=&#34;flutter logo&#34; height=&#34;80&#34; style=&#34;margin-right:25px;&#34;&gt;
